# --- Ethereum side ---
# Local Hardhat node (npx hardhat node): http://127.0.0.1:8545
# Sepolia (once ready for a public testnet demo): https://sepolia.infura.io/v3/YOUR_KEY
ETH_RPC_URL=http://127.0.0.1:8545
NOCTIS_LOCK_ADDRESS=0x0000000000000000000000000000000000000000
# ECDSA key whose signature NoctisLock.unlock() checks against `relayer` on-chain.
# Generate a dedicated key for this - do not reuse a personal wallet. For a local
# Hardhat node, one of its default funded accounts is fine for a demo.
RELAYER_ETH_PRIVATE_KEY=

# --- Midnight side ---
# Network the relayer's Midnight wallet connects to - must match how the wrapper
# contract was deployed (midnight/ `npm run deploy`). Defaults to the local devnet.
MIDNIGHT_NETWORK=undeployed
NOCTIS_WRAPPER_CONTRACT_ADDRESS=
# Relayer's Midnight secret key (proves relayer identity to mint()). Must match the
# key the contract was deployed with - defaults to reading midnight/.noctis-relayer-key
# if unset.
RELAYER_MIDNIGHT_SECRET_KEY=
